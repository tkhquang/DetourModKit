# DetourModKit CMake package configuration file (.in template)

@PACKAGE_INIT@

set(DetourModKit_VERSION "@PROJECT_VERSION@")

# --- ABI / toolchain compatibility contract ---
# DetourModKit is a C++23 *static* library and its entire exported surface is C++ -- there is no extern "C"
# boundary anywhere in the public headers. The archive therefore hard-codes the compiler's name mangling, its
# exception model, and the exact memory layout of every standard-library type that crosses the API (std::string,
# std::vector, std::expected, std::move_only_function, and the containers inside Result<T>). None of that is
# stable across toolchains or even across STL debug levels of the same toolchain, so a consumer MUST link this
# package with a build that matches on every one of these axes:
#   * Same compiler family and ABI. MinGW-GCC archives and MSVC archives are not interchangeable; a release is
#     compiler-specific by construction.
#   * Same C++ standard library implementation and a C++23-or-newer language level.
#   * Matching CRT / iterator-debug configuration. On MSVC, _ITERATOR_DEBUG_LEVEL and the /MD vs /MDd runtime
#     must agree with the archive; a mismatch changes container layout and surfaces as LNK2038 at best or silent
#     ODR undefined behaviour at worst.
# There is no ABI shim to paper over a mismatch: consume DetourModKit from the same toolchain that produced the
# installed prefix. The STATUS line below restates this so it is visible in a fresh consumer's configure log.

# --- Static dependency archives (DetourModKit::deps) ---
# DetourModKit is a static library; its SafetyHook/Zydis/Zycore dependencies are
# shipped as plain archives next to it. They cannot be re-exported as CMake
# targets (each already belongs to its own export set, and a transitively
# required target may live in only one), so they are exposed here as a single
# INTERFACE imported target that the installed DetourModKit target links for its
# INSTALL interface. A static archive does not absorb the objects of the
# libraries it links, so this link is genuinely required; a dependent is listed
# before its dependency to satisfy single-pass linkers.
if(NOT TARGET DetourModKit::deps)
    add_library(DetourModKit::deps INTERFACE IMPORTED)
    set(_dmk_dep_libs "")
    foreach(_dmk_lib @_DMK_DEP_ARCHIVE_NAMES@)
        list(APPEND _dmk_dep_libs "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_LIBDIR@/${_dmk_lib}")
    endforeach()
    if(_dmk_dep_libs)
        set_target_properties(DetourModKit::deps PROPERTIES
            INTERFACE_LINK_LIBRARIES "${_dmk_dep_libs}"
            INTERFACE_INCLUDE_DIRECTORIES "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@")
    endif()
    unset(_dmk_dep_libs)
endif()

# --- Import Targets ---
# Includes the DetourModKitTargets.cmake file generated by install(EXPORT),
# which defines the DetourModKit::DetourModKit imported target. Its INSTALL
# interface links DetourModKit::deps (defined above).
if(NOT TARGET DetourModKit::DetourModKit)
    include("${CMAKE_CURRENT_LIST_DIR}/DetourModKitTargets.cmake")
endif()

check_required_components(DetourModKit)

message(STATUS "Found DetourModKit: ${DetourModKit_VERSION}")
message(STATUS "DetourModKit ABI: C++23 static library, no extern \"C\" boundary -- "
  "link only from the same compiler/STL/CRT toolchain that built this prefix.")
